FLASK_ENV=production
SECRET_KEY=change-me-with-a-long-random-value

# Primary MVP provider: Google PageSpeed Insights API.
ANALYSIS_PROVIDER=pagespeed
PAGESPEED_API_KEY=optional-but-recommended-for-automated-usage
PAGESPEED_STRATEGY=desktop
PAGESPEED_LOCALE=it
PAGESPEED_TIMEOUT=120
PAGESPEED_CACHE_TTL=86400
PAGESPEED_CACHE_MAX_ENTRIES=128
INLINE_ANALYSIS_ENABLED=false

# Optional fallback provider: dedicated Lighthouse worker.
ANALYSIS_WORKER_URL=
ANALYSIS_WORKER_TOKEN=
WORKER_REQUEST_TIMEOUT=290
REQUIRE_ANALYSIS_AUTH=false

# Keep these enabled only on local/worker Lighthouse runtimes.
LIGHTHOUSE_ENABLED=true
BROWSER_ANALYSIS_ENABLED=true

MAX_MONTHLY_VISITS=10000000
